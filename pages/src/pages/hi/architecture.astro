---
import ArchitecturePageContent from "@/components/page-content/ArchitecturePageContent.astro";
import { getMessages } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "hi" as const;
const messages = getMessages(locale);
---

<BaseLayout
  title={messages.pageMeta.architectureTitle}
  description={messages.pageMeta.architectureDescription}
  activePage="architecture"
  locale={locale}
>
  <ArchitecturePageContent messages={messages} />
</BaseLayout>
