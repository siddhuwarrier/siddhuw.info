---
import ContactPageContent from "@/components/page-content/ContactPageContent.astro";
import { turnstileSiteKey } from "@/config/turnstile";
import { getMessages } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "en" as const;
const messages = getMessages(locale);
---

<BaseLayout
  title={messages.pageMeta.contactTitle}
  description={messages.pageMeta.contactDescription}
  activePage="contact"
  locale={locale}
>
  <link slot="head" rel="preconnect" href="https://challenges.cloudflare.com" />
  <ContactPageContent messages={messages} turnstileSiteKey={turnstileSiteKey} />
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</BaseLayout>
