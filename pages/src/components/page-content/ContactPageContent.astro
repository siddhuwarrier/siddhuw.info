---
import { profileEmail, profileLinks } from "@/config/profile";
import type { Messages } from "@/i18n";

type Props = {
  messages: Messages;
  turnstileSiteKey: string;
};

const { messages, turnstileSiteKey } = Astro.props;
---

<main class="mx-auto w-full max-w-6xl px-6 py-10 lg:px-12 lg:py-14">
  <section aria-labelledby="contact-me-title" class="space-y-5">
    <h1 id="contact-me-title" class="text-4xl font-bold tracking-tight sm:text-5xl">{messages.contact.heading}</h1>
    <p id="contact-intro" class="max-w-xl text-base-content/80" data-email="hi@mail.siddhuw.uk">
      {messages.contact.introPrefix}<a id="contact-email-link" class="link link-primary hidden" href=""></a><span id="contact-email-placeholder" class="italic opacity-60">…</span>{messages.contact.introSuffix}
    </p>
    <form
      id="contact-form"
      class="card w-full max-w-xl bg-base-100 shadow-xl"
      data-sitekey={turnstileSiteKey}
      data-submit-label={messages.contact.formSubmit}
      data-submitting-label={messages.contact.formSubmitting}
      data-error-label={messages.contact.formError}
      data-success-label={messages.contact.formSuccess}
    >
      <div class="card-body gap-4">
        <div class="form-control w-full">
          <label class="label" for="contact-email">
            <span class="label-text">{messages.contact.formEmailLabel}</span>
          </label>
          <input
            id="contact-email"
            name="email"
            type="email"
            required
            placeholder={messages.contact.formEmailPlaceholder}
            class="input input-bordered w-full"
          />
        </div>

        <div class="form-control w-full">
          <label class="label" for="contact-message">
            <span class="label-text">{messages.contact.formMessageLabel}</span>
          </label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            placeholder={messages.contact.formMessagePlaceholder}
            class="textarea textarea-bordered w-full"
          ></textarea>
        </div>

        <div id="turnstile-container" class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark" data-callback="onTurnstileSuccess"></div>

        <p id="contact-error" class="text-error text-sm hidden"></p>

        <div class="card-actions justify-end">
          <button id="contact-submit" type="submit" class="btn btn-primary">
            {messages.contact.formSubmit}
          </button>
        </div>
      </div>
    </form>
    <div id="contact-success" class="alert alert-info w-full max-w-xl hidden" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="h-6 w-6 shrink-0 stroke-current">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <span id="contact-success-text"></span>
    </div>
  </section>
</main>

<script>
  import { initContactForm, onTurnstileSuccess } from "@/features/contact/contact-form";
  (window as unknown as Record<string, unknown>).onTurnstileSuccess = onTurnstileSuccess;
  initContactForm();
  document.addEventListener("astro:after-swap", () => {
    (window as unknown as Record<string, unknown>).onTurnstileSuccess = onTurnstileSuccess;
    initContactForm();
  });
</script>
